# ═════════════════════════════════════════════════════════════════════════════
# HRL SYNC HUB v2.0-PRO — BACKEND CONFIGURATION (SUPABASE + VPS)
# ═════════════════════════════════════════════════════════════════════════════

# SERVER settings
NODE_ENV=production
PORT=3001
API_URL=https://hrl-sync-hub.hardbanrecordslab.online
ALLOWED_ORIGINS=https://app.hrl-sync-hub.hardbanrecordslab.online,http://localhost:5173

# DATABASE (Supabase PostgreSQL Connection)
# Get this from Supabase Dashboard -> Settings -> Database -> Connection String (PostgreSQL)
# Format: postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DB_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# SUPABASE AUTH (Optional - if using Supabase for user authentication)
USE_SUPABASE_AUTH=true
SUPABASE_URL=https://[PROJECT_ID].supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# SECURITY (JWT & Encryption)
# Generate secure keys (e.g., using openssl rand -base64 48)
JWT_SECRET=your_secure_jwt_secret_key
ENCRYPTION_KEY=your_32_character_encryption_key
JWT_EXPIRES_IN=24h

# AI ENGINES (Premium Hub Integration)
# Groq (Llama 3) for quick analysis, Gemini for deep marketing insights
GROQ_API_KEY=gsk_your_groq_api_key
GEMINI_API_KEY=your_gemini_api_key

# STORAGE & AUTH (Google Integration)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://hrl-sync-hub.hardbanrecordslab.online/api/auth/google/callback
GOOGLE_DRIVE_ROOT_FOLDER_ID=your_google_drive_folder_id

# EMAIL (SMTP/Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
EMAIL_FROM="HRL Sync Hub <noreply@hardbanrecordslab.online>"

# BUSINESS & CUSTOM DOMAINS
EMBED_ALLOWED_DOMAINS=hardbanrecordslab.online,*.wordpress.com

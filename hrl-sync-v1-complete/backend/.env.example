# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://hrlsync.vercel.app
ALLOWED_ORIGINS=https://hrlsync.vercel.app,https://hardbanrecords.com

# ─── PostgreSQL (self-hosted on VPS) ──────────────────────────────────────────
# Install: sudo apt install postgresql-15
# Setup:   sudo -u postgres psql -c "CREATE USER hrlsync WITH PASSWORD 'yourpassword';"
#          sudo -u postgres psql -c "CREATE DATABASE hrlsync OWNER hrlsync;"
DATABASE_URL=postgresql://hrlsync:yourpassword@localhost:5432/hrlsync
DB_SSL=false       # set true if connecting remotely
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Supabase Auth (still using Supabase for auth only, or use JWT below) ─────
# Option A: Keep Supabase only for auth verification
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Option B: Pure JWT (no Supabase) — set USE_SUPABASE_AUTH=false
USE_SUPABASE_AUTH=true
JWT_SECRET=min-32-chars-random-secret-here-hardban-records-lab
JWT_EXPIRES_IN=30d

# ─── Google OAuth & Drive ─────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_REDIRECT_URI=https://api.hardbanrecords.com/api/auth/google/callback
# Service Account JSON (server-side Drive access)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Root folder in Drive where user files live
GOOGLE_DRIVE_ROOT_FOLDER_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs

# ─── Email ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@hardbanrecords.com
SMTP_PASS=app-password
EMAIL_FROM=HRL Sync <noreply@hardbanrecords.com>

# ─── Embed ────────────────────────────────────────────────────────────────────
EMBED_ALLOWED_DOMAINS=hardbanrecords.com,*.wordpress.com
